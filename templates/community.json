        "KickMembers",
        "BanMembers",
        "ModerateMembers",
        "ManageChannels"
      ]
    },
    {
      "name": "Member",
      "color": "#22c55e",
      "hoist": false,
      "mentionable": false,
      "permissions": [
        "ViewChannel",
        "SendMessages",
        "ReadMessageHistory",
        "Connect",
        "Speak"
      ]
    }
  ],
  "categories": [
